diff --git a/applecontainer/options/options.go b/applecontainer/options/options.go
index ab7ea24..91ae2c5 100644
--- a/applecontainer/options/options.go
+++ b/applecontainer/options/options.go
@@ -158,7 +158,7 @@ type ManagementOptions struct {
